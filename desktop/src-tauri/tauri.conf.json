{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "herdeck",
  "version": "0.1.0",
  "identifier": "xyz.vaclavik.herdeck.desktop",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "herdeck",
        "width": 360,
        "height": 600,
        "minWidth": 280,
        "minHeight": 320,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": false,
        "visible": true,
        "shadow": true,
        "skipTaskbar": false
      },
      {
        "label": "config",
        "title": "herdeck — Config",
        "width": 900,
        "height": 680,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "alwaysOnTop": false,
        "transparent": false,
        "visible": false,
        "shadow": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "resources": {
      "resources/herdeck-deckapp": "herdeck-deckapp"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns"
    ]
  }
}
